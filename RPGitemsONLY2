class Shield extends GameItem {
    private final int defenseBonus = 3;

    public Shield() {
        super(
                "Shield",
                ItemType.SPECIAL,
                0,
                "Hand equipment. +3 Defense. Enables Parry against heavy attacks."
        );
    }

    public int getDefenseBonus() {
        return defenseBonus;
    }

    /**
     * Lets battle code know this item enables the Parry action.
     * Your friend can check this when building the action menu.
     */
    public boolean enablesParry() {
        return true;
    }

    /**
     * Main parry mechanic.
     *
     * How it works:
     * - If the enemy attack misses, parry does nothing.
     * - If the enemy attack is LIGHT, parry fails and returns 0.
     * - If the enemy attack is HEAVY and it hits, damage is redirected
     *   back to the enemy instead of hurting the player.
     *
     * Parameters:
     * attackType    -> later your friend can pass "light" or "heavy"
     * hitLands      -> true if enemy accuracy check succeeded
     * enemyAttack   -> enemy base attack stat
     * movePower     -> enemy move power
     * playerDefense -> player's current defense
     *
     * Returns:
     * - reflected damage if parry succeeds
     * - 0 if parry fails or the attack misses
     */
    public int parryDamage(String attackType, boolean hitLands,
                           int enemyAttack, int movePower, int playerDefense) {

        if (!hitLands || attackType == null) {
            return 0;
        }

        if (attackType.equalsIgnoreCase("heavy")) {
            return Math.max(1, enemyAttack + movePower - playerDefense);
        }

        return 0;
    }

    /**
     * Optional helper for battle text.
     */
    public String getParryResultMessage(String attackType, boolean hitLands, int reflectedDamage) {
        if (!hitLands) {
            return "The enemy attack missed, so parry was not needed.";
        }

        if (attackType == null) {
            return "Parry failed.";
        }

        if (attackType.equalsIgnoreCase("heavy") && reflectedDamage > 0) {
            return "Parry successful! You redirect the heavy attack and deal "
                    + reflectedDamage + " damage back to the enemy.";
        }

        return "Parry failed. Light attacks cannot be parried.";
    }

    /**
     * Optional helper for action-menu logic.
     * Assuming your friend already supports equipped shield checking,
     * this makes the shield responsible for exposing the parry action.
     */
    public String getBattleActionName() {
        return "Parry";
    }
}

