/* =========================
   OPTIONAL HELPER METHODS
   ========================= */

class ItemSupport {

    public static boolean playerHasTorch(Player player) {
        for (Item item : player.getInventory()) {
            if (item instanceof Torch || item.getName().equalsIgnoreCase("Torch")) {
                return true;
            }
        }
        return false;
    }

    public static boolean playerHasKey(Player player, String keyId) {
        for (Item item : player.getInventory()) {
            if (item instanceof Key) {
                Key key = (Key) item;
                if (key.getKeyId().equalsIgnoreCase(keyId)) {
                    return true;
                }
            }
        }
        return false;
    }

    public static WeaponItem getWeaponByName(Player player, String weaponName) {
        for (Item item : player.getInventory()) {
            if (item instanceof WeaponItem && item.getName().equalsIgnoreCase(weaponName)) {
                return (WeaponItem) item;
            }
        }
        return null;
    }

    public static boolean useInventoryItem(Player player, int index, ItemContext context) {
        if (index < 0 || index >= player.getInventory().size()) {
            System.out.println("Invalid item index.");
            return false;
        }

        Item rawItem = player.getInventory().get(index);

        if (!(rawItem instanceof GameItem)) {
            System.out.println(rawItem.getName() + " is still using the old item format.");
            return false;
        }

        GameItem item = (GameItem) rawItem;
        boolean consumed = item.use(player, context);

        if (consumed) {
            player.removeItem(index);
        }

        return consumed;
    }
}
